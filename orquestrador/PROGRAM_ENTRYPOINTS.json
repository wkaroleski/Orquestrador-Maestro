{
  "version": 1,
  "owner": "{{USER_NAME}}",
  "home": "{{USER_HOME}}",
  "principle": "Keep each tool's native entrypoints stable; sync compact canonical content into the paths each tool already reads.",
  "capabilityModel": {
    "install": "Installers copy fixed symbolic targets only; they never accept arbitrary source or destination paths from CLI flags.",
    "activation": "Entrypoints point each tool back to AGENTS.md, .orquestrador/rules.md, .orquestrador/maestro.md, and project DEV documentation when present.",
    "contextEconomy": "Tools should load compact contracts, indexes, routers, and task-specific skills before opening large catalogs or full DEV trees.",
    "uninstall": "Uninstall is conservative: core files can be removed, shared skill/tool directories remove only files mapped from this public snapshot."
  },
  "canonical": {
    "rules": "{{USER_HOME}}/.orquestrador/rules.md",
    "maestro": "{{USER_HOME}}/.orquestrador/maestro.md",
    "hooks": "{{USER_HOME}}/.orquestrador/hooks.md",
    "skillsIndex": "{{USER_HOME}}/.orquestrador/SKILLS_INDEX.md",
    "skillsRouter": "{{USER_HOME}}/.orquestrador/SKILLS_ROUTER.json",
    "skillAliases": "{{USER_HOME}}/.orquestrador/SKILL_ALIASES.json",
    "skillChains": "{{USER_HOME}}/.orquestrador/SKILL_CHAINS.json",
    "skillExecutionProfiles": "{{USER_HOME}}/.orquestrador/SKILL_EXECUTION_PROFILES.json",
    "skillUsageSchema": "{{USER_HOME}}/.orquestrador/SKILL_USAGE_SCHEMA.json",
    "projectDevHierarchy": "{{USER_HOME}}/.orquestrador/PROJECT_DEV_HIERARCHY.md",
    "projectDevInitializerWindows": "{{USER_HOME}}/.orquestrador/bin/init-project-dev.ps1",
    "projectDevInitializerUnix": "{{USER_HOME}}/.orquestrador/bin/init-project-dev.sh",
    "skillSyncWindows": "{{USER_HOME}}/.orquestrador/sync-skills.ps1",
    "skillSyncUnix": "{{USER_HOME}}/.orquestrador/sync-skills.sh",
    "skillsRoot": "{{USER_HOME}}/.orquestrador/skills",
    "globalSkillsRoot": "{{USER_HOME}}/.global-skills"
  },
  "programs": {
    "codex": {
      "component": "codex",
      "capabilities": {
        "autoActivates": true,
        "hookSupport": "AGENTS.md and user skill discovery",
        "commandRewrite": false,
        "statusline": "external/OMX when installed",
        "settingsMerge": "file copy with backup",
        "verify": "scripts/verify-install.ps1 or scripts/verify-install.sh"
      },
      "primary": [
        "{{USER_HOME}}/.codex/config.toml",
        "{{USER_HOME}}/.codex/AGENTS.md",
        "{{USER_HOME}}/AGENTS.md"
      ],
      "skillsRoot": "{{USER_HOME}}/.codex/skills",
      "notes": "Codex discovers user skills from .codex/skills and project/global AGENTS.md files."
    },
    "opencode": {
      "component": "opencode",
      "capabilities": {
        "autoActivates": true,
        "hookSupport": "global AGENTS.md, opencode.json instructions, hooks.md",
        "commandRewrite": false,
        "statusline": false,
        "settingsMerge": "file copy with backup",
        "verify": "OpenCode config includes ~/.orquestrador/rules.md and ~/.orquestrador/maestro.md"
      },
      "primary": [
        "{{USER_HOME}}/.config/opencode/AGENTS.md",
        "{{USER_HOME}}/.config/opencode/opencode.json",
        "{{USER_HOME}}/.opencode/default-skill.json",
        "{{USER_HOME}}/.opencode/SYSTEM.md",
        "{{USER_HOME}}/.opencode/rules.md",
        "{{USER_HOME}}/.opencode/maestro.md",
        "{{USER_HOME}}/.opencode/hooks.md",
        "{{USER_HOME}}/.opencode/SKILLS_INDEX.md"
      ],
      "skillsRoot": "{{USER_HOME}}/.opencode/skills",
      "compatibilityRoots": [
        "{{USER_HOME}}/.agents/skills"
      ],
      "notes": "OpenCode keeps its own .opencode entrypoints; legacy .agents/skills remains populated for compatibility."
    },
    "antigravity": {
      "component": "antigravity",
      "capabilities": {
        "autoActivates": true,
        "hookSupport": "antigravity-rules.json plus .ai-standards",
        "commandRewrite": false,
        "statusline": false,
        "settingsMerge": "file copy with backup",
        "verify": "Antigravity JSON files parse and reference .orquestrador/.ai-standards"
      },
      "primary": [
        "{{USER_HOME}}/antigravity-rules.json",
        "{{USER_HOME}}/.antigravity/antigravity.json",
        "{{USER_HOME}}/.antigravity/settings.json"
      ],
      "standardsRoot": "{{USER_HOME}}/.ai-standards",
      "skillsRoot": "{{USER_HOME}}/.antigravity-skills/skills",
      "optionalEndpoint": "ws://localhost:3001"
    },
    "claude": {
      "component": "claude",
      "capabilities": {
        "autoActivates": true,
        "hookSupport": "CLAUDE.md, SYSTEM_PROMPT.md, hooks.md, skills",
        "commandRewrite": "not installed by default; future compact command wrappers must be opt-in",
        "statusline": false,
        "settingsMerge": "file copy with backup",
        "verify": "Claude global memory includes DEV/WORKLOG.md guidance"
      },
      "primary": [
        "{{USER_HOME}}/.claude/CLAUDE.md",
        "{{USER_HOME}}/.claude/SYSTEM_PROMPT.md",
        "{{USER_HOME}}/.claude/hooks.md"
      ],
      "skillsRoot": "{{USER_HOME}}/.claude/skills",
      "notes": "Claude Code loads user memory from .claude/CLAUDE.md."
    },
    "cursor": {
      "component": "cursor",
      "capabilities": {
        "autoActivates": true,
        "hookSupport": "AGENTS.md, MDC rule, hooks.md, skills",
        "commandRewrite": false,
        "statusline": false,
        "settingsMerge": "file copy with backup",
        "verify": "Cursor AGENTS/rule files include DEV/WORKLOG.md guidance"
      },
      "primary": [
        "{{USER_HOME}}/.cursor/AGENTS.md",
        "{{USER_HOME}}/.cursor/rules/orquestrador-maestro.mdc",
        "{{USER_HOME}}/.cursor/hooks.md"
      ],
      "skillsRoot": "{{USER_HOME}}/.cursor/skills",
      "notes": "Cursor supports AGENTS.md and rule files; the installer writes both as portable local entrypoints."
    },
    "gemini": {
      "component": "gemini",
      "capabilities": {
        "autoActivates": true,
        "hookSupport": "GEMINI.md, hooks.md, skills",
        "commandRewrite": false,
        "statusline": false,
        "settingsMerge": "file copy with backup",
        "verify": "Gemini global context includes DEV/WORKLOG.md guidance"
      },
      "primary": [
        "{{USER_HOME}}/.gemini/GEMINI.md",
        "{{USER_HOME}}/.gemini/hooks.md"
      ],
      "skillsRoot": "{{USER_HOME}}/.gemini/skills",
      "notes": "Gemini CLI loads global context from .gemini/GEMINI.md by default."
    },
    "windsurf": {
      "component": "windsurf",
      "capabilities": {
        "autoActivates": true,
        "hookSupport": "Windsurf/Cascade global rules, hooks.md, skills",
        "commandRewrite": false,
        "statusline": false,
        "settingsMerge": "file copy with backup",
        "verify": "Windsurf global rules include DEV/WORKLOG.md guidance"
      },
      "primary": [
        "{{USER_HOME}}/.codeium/windsurf/memories/global_rules.md",
        "{{USER_HOME}}/.windsurf/hooks.md"
      ],
      "skillsRoot": "{{USER_HOME}}/.windsurf/skills",
      "notes": "Windsurf Cascade loads global rules from .codeium/windsurf/memories/global_rules.md."
    }
  },
  "workspaceBootstraps": {
    "vscode": {
      "projectFiles": [
        ".github/copilot-instructions.md",
        ".vscode/extensions.json"
      ],
      "notes": "Bootstrap generated by init-project-dev for VS Code and GitHub Copilot."
    },
    "aider": {
      "projectFiles": [
        ".aider.conf.yml"
      ],
      "notes": "Project config generated by init-project-dev for Aider."
    },
    "continue": {
      "projectFiles": [
        ".continue/rules/00-orquestrador-maestro.md"
      ],
      "notes": "Project rule generated by init-project-dev for Continue."
    },
    "jetbrains": {
      "projectFiles": [
        ".aiassistant/rules/orquestrador-maestro.md"
      ],
      "notes": "Project rule generated by init-project-dev for JetBrains AI Assistant."
    },
    "cline": {
      "projectFiles": [
        ".clinerules"
      ],
      "notes": "Project rule generated by init-project-dev for Cline."
    },
    "windsurf": {
      "projectFiles": [
        ".windsurfrules"
      ],
      "notes": "Project rule generated by init-project-dev for Windsurf project-level compatibility."
    }
  }
}
